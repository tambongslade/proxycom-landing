###
# ==============================================================================
# Region Endpoints
# ==============================================================================
@regionId = 1

### Create a new region (Requires Admin Auth)
# @name createRegion
POST {{baseUrl}}/regions
Authorization: {{adminToken}}
Content-Type: application/json

{
  "name": "Centre"
}

### Create another region (Requires Admin Auth)
# @name createRegionLittoral
POST {{baseUrl}}/regions
Authorization: {{adminToken}}
Content-Type: application/json

{
  "name": "Littoral"
}

### Get all regions (Public)
# @name getAllRegions
GET {{baseUrl}}/regions

### Get region by ID (Public)
# Update @regionId with the ID of the region to fetch.
# @name getRegionById
GET {{baseUrl}}/regions/{{regionId}}

### Update an existing region (Requires Admin Auth)
# Update @regionId with the ID of the region to update.
# @name updateRegion
PUT {{baseUrl}}/regions/{{regionId}}
Authorization: {{adminToken}}
Content-Type: application/json

{
  "name": "Central Region"
}

### Delete a region (Requires Admin Auth)
# Update @regionId with the ID of the region to delete.
# Note: This will fail if the region has associated Divisions.
# @name deleteRegion
DELETE {{baseUrl}}/regions/{{regionId}}
Authorization: {{adminToken}} 